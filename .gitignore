# Track only curated top-level content in this repository
/*
!/.gitignore
!/README.md
!/CONTRIBUTING.md
!/AI_AGENT_PROMPT.md
!/.github/
!/.github/**
!/docs/
!/docs/**
!/universal_myPet/
!/universal_myPet/**

# Python caches
**/__pycache__/
*.pyc
*.pyo

# Local session and runtime state
universal_myPet/token.md
universal_myPet/cookie.md
universal_myPet/token copy.md
universal_myPet/cookie copy.md
universal_myPet/state/checkpoints.json
universal_myPet/ROLLBACK_BODY.json

# Runtime logs and distributions
universal_myPet/logs/*.txt
universal_myPet/dist/

# Local temp books and office lock files
universal_myPet/test_books/
universal_myPet/~$*.xlsm

# Large local media (avoid accidental commits)
universal_myPet/files/**/*.mp4
universal_myPet/files/**/*.mov
universal_myPet/files/**/*.avi
